{
  "name": "@rc-component/father-plugin",
  "version": "2.2.0",
  "description": "🧱 Shared father build plugin for rc-component packages.",
  "keywords": [],
  "repository": "https://github.com/react-component/father-plugin.git",
  "license": "MIT",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "father build",
    "dev": "father dev",
    "lint": "npm run lint:es",
    "lint:es": "eslint \"{src,test}/**/*.{js,jsx,ts,tsx}\"",
    "prepare": "husky",
    "prepublishOnly": "father doctor && npm run build && rc-np"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{md,json}": [
      "prettier --write --no-error-on-unmatched-pattern"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --parser=typescript --write"
    ]
  },
  "dependencies": {
    "fs-extra": "^11.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.1.2",
    "@commitlint/config-conventional": "^17.1.0",
    "@rc-component/np": "^1.0.4",
    "@types/eslint": "^8.56.12",
    "@types/fs-extra": "^11.0.4",
    "@umijs/lint": "^4",
    "eslint": "^9.39.4",
    "father": "^4.6.24",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2"
  },
  "peerDependencies": {
    "father": "^4.6.24"
  },
  "publishConfig": {
    "access": "public"
  },
  "authors": [
    "PeachScript <scdzwyxst@gmail.com>"
  ]
}
